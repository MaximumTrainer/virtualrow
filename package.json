{
  "name": "virtualrow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "pretest:e2e": "npx playwright install --with-deps",
    "test:e2e": "npx playwright test --config=playwright/playwright.config.ts",
    "test:e2e:ci": "npx playwright test --config=playwright/playwright.config.ci.ts --retries=2",
    "start:sim": "node ./playwright/simulators/sim-server.cjs",
    "db:setup": "npx tsx scripts/db/setup.ts",
    "db:migrate": "npx tsx scripts/db/migrate.ts up",
    "db:migrate:status": "npx tsx scripts/db/migrate.ts status",
    "db:rollback": "npx tsx scripts/db/migrate.ts down",
    "db:rollback:all": "npx tsx scripts/db/migrate.ts down:all"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "axios": "^1.13.2",
    "chart.js": "^4.5.1",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.46.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^24.10.0",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vitest": "^1.6.0",
    "ws": "^8.17.0"
  }
}
